# Application
APP_NAME=FastAPI Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173"]

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PDF uploads (metadata in DB, files under this folder relative to backend cwd)
UPLOAD_ROOT=storage/uploads
MAX_PDF_UPLOAD_BYTES=20971520

# LandingAI ADE — parse PDF to markdown, then schema extract (https://docs.landing.ai/ade/)
# If extract says "not configured" but this file has a key: remove empty LANDINGAI_API_KEY
# from Windows / IDE environment, or rely on env_ignore_empty in settings (enabled by default).
LANDINGAI_API_KEY=
LANDINGAI_BASE_URL=https://api.va.landing.ai
LANDINGAI_PARSE_MODEL=dpt-2-latest
LANDINGAI_EXTRACT_MODEL=extract-latest
