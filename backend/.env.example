# Application
APP_NAME=FastAPI Service
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:5173"]

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PDF uploads + CV extraction JSON: folder is relative to backend/ (not shell cwd).
# JSON path: {UPLOAD_ROOT}/extract/{file_id}.json
UPLOAD_ROOT=storage/uploads
MAX_PDF_UPLOAD_BYTES=20971520

# LandingAI ADE — parse PDF to markdown, then schema extract (https://docs.landing.ai/ade/)
# If extract says "not configured" but this file has a key: remove empty LANDINGAI_API_KEY
# from Windows / IDE environment, or rely on env_ignore_empty in settings (enabled by default).
LANDINGAI_API_KEY=
LANDINGAI_BASE_URL=https://api.va.landing.ai
LANDINGAI_PARSE_MODEL=dpt-2-latest
LANDINGAI_EXTRACT_MODEL=extract-latest

# TinyFish — AI web agent (https://docs.tinyfish.ai/quick-start)
# Default search URL is CareerBuilder if TINYFISH_JOB_SEARCH_URL is unset/empty.
TINYFISH_API_KEY=
TINYFISH_BASE_URL=
# Optional override — only automate where the site’s terms allow it.
TINYFISH_JOB_SEARCH_URL=
TINYFISH_SSE_TIMEOUT_SECONDS=180
# Timeout (seconds) for the single Harvard catalog TinyFish run.
TINYFISH_HARVARD_TIMEOUT_SECONDS=180

# Harvard major catalog: one public page URL for TinyFish enrichment; merged with seed JSON; DB TTL cache.
HARVARD_CATALOG_URL=https://college.harvard.edu/advising/fields-study
HARVARD_CATALOG_CACHE_TTL_SECONDS=86400

# OpenAI — program assessment (school) and optional job learning plan after TinyFish search
OPENAI_API_KEY=
# Chat model for JSON learning plan (e.g. gpt-4o-mini, or your account’s latest)
OPENAI_JOB_LEARNING_MODEL=gpt-4o-mini
